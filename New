    <script>
        // Game State
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        
        let gameState = {
            player: { x: 0, y: 0, vx: 0, vy: 0, onGround: false, avatar: '👦', name: 'لاعب' },
            coins: 0,
            level: 1,
            blocksPlaced: 0,
            selectedBlock: '🧱',
            world: [],
            camera: { x: 0, y: 0 },
            players: [],
            chat: []
        };
        
        const BLOCK_SIZE = 40;
        const GRAVITY = 0.5;
        const JUMP_FORCE = -12;
        const SPEED = 5;
        
        const BLOCKS = {
            '🧱': { color: '#8B4513', solid: true },
            '🟫': { color: '#D2691E', solid: true },
            '🟩': { color: '#228B22', solid: true },
            '🟦': { color: '#1E90FF', solid: true },
            '⬜': { color: '#F5F5F5', solid: true },
            '🟥': { color: '#DC143C', solid: true },
            '🟨': { color: '#FFD700', solid: true },
            '🟪': { color: '#9370DB', solid: true },
            '🌳': { color: '#006400', solid: true },
            '💎': { color: '#00CED1', solid: true },
            '🔥': { color: '#FF4500', solid: false },
            '💧': { color: '#4169E1', solid: false }
        };
        
        // Resize canvas
        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();
        
        // Start Game
        function startGame() {
            const name = document.getElementById('playerName').value || 'لاعب';
            const avatar = document.querySelector('.avatar-option.selected').dataset.avatar;
            
            gameState.player.name = name;
            gameState.player.avatar = avatar;
            
            document.getElementById('startScreen').style.display = 'none';
            document.getElementById('gameUI').style.display = 'flex';
            document.getElementById('joystickArea').style.display = 'block';
            document.getElementById('actionButtons').style.display = 'flex';
            
            initWorld();
            initBuildMenu();
            gameLoop();
            
            showNotification('🎉 مرحباً ' + name + '! استخدم الJoystick للمشي');
        }
        
        // Avatar Selection
        document.querySelectorAll('.avatar-option').forEach(opt => {
            opt.addEventListener('click', () => {
                document.querySelectorAll('.avatar-option').forEach(o => o.classList.remove('selected'));
                opt.classList.add('selected');
            });
        });
        
        // Initialize World
        function initWorld() {
            // Ground
            for (let x = -50; x < 50; x++) {
                gameState.world.push({ x: x * BLOCK_SIZE, y: 300, type: '🟫' });
            }
            
            // Random trees and rocks
            for (let i = 0; i < 20; i++) {
                const x = (Math.random() * 80 - 40) * BLOCK_SIZE;
                gameState.world.push({ x: x, y: 260, type: '🌳' });
            }
            
            // Coins
            for (let i = 0; i < 30; i++) {
                const x = (Math.random() * 80 - 40) * BLOCK_SIZE;
                const y = 200 - Math.random() * 150;
                gameState.world.push({ x: x, y: y, type: '🪙', collectible: true });
            }
        }
        
        // Build Menu
        function initBuildMenu() {
            const grid = document.getElementById('itemGrid');
            Object.keys(BLOCKS).forEach(block => {
                const btn = document.createElement('div');
                btn.className = 'item-btn' + (block === gameState.selectedBlock ? ' selected' : '');
                btn.textContent = block;
                btn.onclick = () => selectBlock(block, btn);
                grid.appendChild(btn);
            });
        }
        
        function selectBlock(block, btn) {
            gameState.selectedBlock = block;
            document.querySelectorAll('.item-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
        }
        
        function toggleMenu() {
            document.getElementById('buildMenu').classList.toggle('active');
        }
        
        // Chat
        function toggleChat() {
            document.getElementById('chatBox').classList.toggle('active');
            if (document.getElementById('chatBox').classList.contains('active')) {
                document.getElementById('chatInput').focus();
            }
        }
        
        function sendChat(e) {
            if (e.key === 'Enter') {
                const input = document.getElementById('chatInput');
                const msg = input.value.trim();
                if (msg) {
                    addChatMessage(gameState.player.name, msg);
                    input.value = '';
                }
            }
        }
        
        function addChatMessage(name, msg) {
            const container = document.getElementById('chatMessages');
            const div = document.createElement('div');
            div.className = 'chat-msg';
            div.innerHTML = '<span class="chat-name">' + name + ':</span> ' + msg;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
            
            gameState.chat.push({ name, msg, time: Date.now() });
        }
        
        // Joystick
        let joystickData = { active: false, dx: 0, dy: 0 };
        const joystick = document.getElementById('joystick');
        const knob = document.getElementById('joystickKnob');
        
        joystick.addEventListener('touchstart', handleJoystickStart);
        joystick.addEventListener('touchmove', handleJoystickMove);
        joystick.addEventListener('touchend', handleJoystickEnd);
        
        function handleJoystickStart(e) {
            e.preventDefault();
            joystickData.active = true;
            handleJoystickMove(e);
        }
        
        function handleJoystickMove(e) {
            e.preventDefault();
            if (!joystickData.active) return;
            
            const touch = e.touches[0];
            const rect = joystick.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            let dx = touch.clientX - centerX;
            let dy = touch.clientY - centerY;
            
            const distance = Math.sqrt(dx * dx + dy * dy);
            const maxDistance = 30;
            
            if (distance > maxDistance) {
                dx = (dx / distance) * maxDistance;
                dy = (dy / distance) * maxDistance;
            }
            
            knob.style.transform = 'translate(calc(-50% + ' + dx + 'px), calc(-50% + ' + dy + 'px))';
            
            joystickData.dx = dx / maxDistance;
            joystickData.dy = dy / maxDistance;
        }
        
        function handleJoystickEnd(e) {
            e.preventDefault();
            joystickData.active = false;
            joystickData.dx = 0;
            joystickData.dy = 0;
            knob.style.transform = 'translate(-50%, -50%)';
        }
        
        // Actions
        function jump() {
            if (gameState.player.onGround) {
                gameState.player.vy = JUMP_FORCE;
                gameState.player.onGround = false;
            }
        }
        
        function placeBlock() {
            const px = gameState.player.x;
            const py = gameState.player.y;
            
            // Place in front of player
            const facing = joystickData.dx >= 0 ? 1 : -1;
            const bx = Math.round((px + facing * BLOCK_SIZE * 2) / BLOCK_SIZE) * BLOCK_SIZE;
            const by = Math.round(py / BLOCK_SIZE) * BLOCK_SIZE;
            
            // Check if empty
            const exists = gameState.world.find(b => Math.abs(b.x - bx) < 5 && Math.abs(b.y - by) < 5);
            if (!exists) {
                gameState.world.push({ x: bx, y: by, type: gameState.selectedBlock });
                gameState.blocksPlaced++;
                updateUI();
                showNotification('🧱 تم البناء!');
            }
        }
        
        // Update UI
        function updateUI() {
            document.getElementById('coins').textContent = gameState.coins;
            document.getElementById('level').textContent = gameState.level;
            document.getElementById('blocks').textContent = gameState.blocksPlaced;
        }
        
        function showNotification(text) {
            const notif = document.createElement('div');
            notif.className = 'notification';
            notif.textContent = text;
            document.body.appendChild(notif);
            setTimeout(() => notif.remove(), 3000);
        }
        
        // Physics
        function updatePhysics() {
            const p = gameState.player;
            
            // Movement
            p.vx = joystickData.dx * SPEED;
            
            // Gravity
            p.vy += GRAVITY;
            
            // Apply velocity
            p.x += p.vx;
            p.y += p.vy;
            
            // Collision with ground blocks
            p.onGround = false;
            gameState.world.forEach(block => {
                if (BLOCKS[block.type] && BLOCKS[block.type].solid) {
                    const bx = block.x;
                    const by = block.y;
                    
                    // Simple AABB collision
                    if (p.x + 15 > bx - BLOCK_SIZE/2 && p.x - 15 < bx + BLOCK_SIZE/2 &&
                        p.y + 20 > by - BLOCK_SIZE/2 && p.y - 20 < by + BLOCK_SIZE/2) {
                        
                        // Landing on top
                        if (p.vy > 0 && p.y < by) {
                            p.y = by - BLOCK_SIZE/2 - 20;
                            p.vy = 0;
                            p.onGround = true;
                        }
                    }
                }
                
                // Collect coins
                if (block.collectible) {
                    const dist = Math.sqrt((p.x - block.x)**2 + (p.y - block.y)**2);
                    if (dist < 30) {
                        gameState.coins += 10;
                        updateUI();
                        block.collected = true;
                        showNotification('🪙 +10 عملات!');
                    }
                }
            });
            
            // Remove collected items
            gameState.world = gameState.world.filter(b => !b.collected);
            
            // Level up
            if (gameState.coins >= gameState.level * 100) {
                gameState.level++;
                updateUI();
                showNotification('⭐ مستوى ' + gameState.level + '!');
            }
            
            // Camera follow
            gameState.camera.x += (p.x - gameState.camera.x) * 0.1;
            gameState.camera.y += (p.y - gameState.camera.y) * 0.1;
        }
        
        // Render
        function render() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Sky gradient
            const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
            gradient.addColorStop(0, '#87CEEB');
            gradient.addColorStop(1, '#E0F6FF');
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Save context for camera
            ctx.save();
            ctx.translate(canvas.width/2 - gameState.camera.x, canvas.height/2 - gameState.camera.y);
            
            // Draw world
            gameState.world.forEach(block => {
                const screenX = block.x - gameState.camera.x + canvas.width/2;
                const screenY = block.y - gameState.camera.y + canvas.height/2;
                
                // Only draw visible blocks
                if (screenX > -50 && screenX < canvas.width + 50 &&
                    screenY > -50 && screenY < canvas.height + 50) {
                    
                    if (block.type === '🪙') {
                        ctx.font = '30px Arial';
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        ctx.fillText('🪙', block.x, block.y);
                    } else if (block.type === '🌳') {
                        ctx.font = '40px Arial';
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        ctx.fillText('🌳', block.x, block.y);
                    } else {
                        const color = BLOCKS[block.type] ? BLOCKS[block.type].color : '#888';
                        ctx.fillStyle = color;
                        ctx.fillRect(block.x - BLOCK_SIZE/2, block.y - BLOCK_SIZE/2, BLOCK_SIZE, BLOCK_SIZE);
                        ctx.strokeStyle = 'rgba(0,0,0,0.2)';
                        ctx.strokeRect(block.x - BLOCK_SIZE/2, block.y - BLOCK_SIZE/2, BLOCK_SIZE, BLOCK_SIZE);
                    }
                }
            });
            
            // Draw player
            const p = gameState.player;
            ctx.font = '40px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(p.avatar, p.x, p.y - 10);
            
            // Player name
            ctx.font = 'bold 12px Tajawal';
            ctx.fillStyle = 'white';
            ctx.strokeStyle = 'black';
            ctx.lineWidth = 3;
            ctx.strokeText(p.name, p.x, p.y - 40);
            ctx.fillText(p.name, p.x, p.y - 40);
            
            ctx.restore();
        }
        
        // Game Loop
        function gameLoop() {
            updatePhysics();
            render();
            requestAnimationFrame(gameLoop);
        }
        
        // Keyboard controls (for testing on desktop)
        const keys = {};
        window.addEventListener('keydown', e => {
            keys[e.key] = true;
            if (e.key === ' ' || e.key === 'ArrowUp') jump();
            if (e.key === 'b') placeBlock();
        });
        window.addEventListener('keyup', e => keys[e.key] = false);
        
        // Desktop joystick simulation
        window.addEventListener('keydown', e => {
            if (e.key === 'ArrowRight') joystickData.dx = 1;
            if (e.key === 'ArrowLeft') joystickData.dx = -1;
        });
        window.addEventListener('keyup', e => {
            if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') joystickData.dx = 0;
        });
    </script>
</body>
</html>"""

